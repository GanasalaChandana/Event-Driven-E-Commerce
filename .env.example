# ─────────────────────────────────────────────────────────────────
# ShopFlow — Environment Variables Reference for Railway Deployment
# Copy and fill these in each Railway service's Variables tab.
# ─────────────────────────────────────────────────────────────────

# ── Shared across ALL services ────────────────────────────────────
JWT_SECRET=change-me-to-a-random-256-bit-secret-in-production
EUREKA_URL=https://<your-eureka-service>.railway.app/eureka/

# ── PostgreSQL (Railway PostgreSQL plugin) ────────────────────────
# Add the Railway PostgreSQL plugin to your project.
# Then reference its variables like below per service:

# user-service
SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/users_db
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}

# product-service  — same plugin, different DB name
SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/products_db

# order-service
SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/orders_db

# inventory-service
SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/inventory_db

# ── Redis (Railway Redis plugin) ──────────────────────────────────
# Add the Railway Redis plugin. Used by inventory-service only.
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

# ── Kafka (Upstash Kafka — free tier) ────────────────────────────
# Sign up at https://console.upstash.com → Create Kafka cluster
# Get bootstrap server + SASL credentials
SPRING_KAFKA_BOOTSTRAP_SERVERS=<upstash-endpoint>:9092
SPRING_KAFKA_PROPERTIES_SASL_MECHANISM=SCRAM-SHA-256
SPRING_KAFKA_PROPERTIES_SECURITY_PROTOCOL=SASL_SSL
SPRING_KAFKA_PROPERTIES_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="<user>" password="<pass>";

# ── Notification Service (Gmail App Password) ─────────────────────
# Enable 2FA on your Gmail → App Passwords → generate one
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ── Build variable (set per Railway service, not an env var) ─────
# In Railway → Service → Settings → Build → Add Variable:
SERVICE_NAME=user-service   # change per service
